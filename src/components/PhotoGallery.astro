---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

type Slide = {
  src: ImageMetadata;
  alt: string;
};

type Props = {
  slides: Slide[];
  /** Responsive variants Astro should generate (px). */
  widths?: number[];
  /** sizes attribute, paired with widths. */
  sizes?: string;
  /** Short label that appears in the cycle indicator (e.g., "exterior"). */
  label?: string;
  /** Eager-load the first slide. Use on the LCP element. */
  eager?: boolean;
  /** object-fit value when CSS overrides intrinsic dimensions. */
  fit?: "cover" | "contain" | "fill" | "none" | "scale-down";
  /** Force a CSS aspect-ratio on the gallery container (e.g., "21/9"). Prevents layout shift between slides of slightly different aspects. */
  aspectRatio?: string;
};

const {
  slides,
  widths,
  sizes,
  label,
  eager = false,
  fit,
  aspectRatio,
}: Props = Astro.props;

const total = slides.length;
const totalLabel = String(total).padStart(2, "0");
const useWidths = widths !== undefined;

const containerStyle = [
  aspectRatio ? `aspect-ratio: ${aspectRatio}` : "",
  fit ? `--gallery-fit: ${fit}` : "",
]
  .filter(Boolean)
  .join("; ");
---

<div
  class="gallery"
  data-gallery
  style={containerStyle ? containerStyle : undefined}
>
  {
    total > 1 ? (
      <button
        type="button"
        class="cycle"
        data-cycle
        aria-label={
          label ? `Cycle ${label} photos` : "Cycle through photos"
        }
      >
        {slides.map((s, i) =>
          useWidths ? (
            <div class="slide" data-slide hidden={i !== 0}>
              <Picture
                src={s.src}
                alt={s.alt}
                widths={widths}
                sizes={sizes}
                loading={i === 0 && eager ? "eager" : "lazy"}
                decoding={i === 0 && eager ? "sync" : "async"}
                fetchpriority={i === 0 && eager ? "high" : "auto"}
                formats={["avif", "webp"]}
              />
            </div>
          ) : (
            <div class="slide" data-slide hidden={i !== 0}>
              <Picture
                src={s.src}
                alt={s.alt}
                width={s.src.width}
                height={s.src.height}
                loading={i === 0 && eager ? "eager" : "lazy"}
                decoding={i === 0 && eager ? "sync" : "async"}
                fetchpriority={i === 0 && eager ? "high" : "auto"}
                formats={["avif", "webp"]}
              />
            </div>
          ),
        )}
      </button>
    ) : useWidths ? (
      <Picture
        src={slides[0].src}
        alt={slides[0].alt}
        widths={widths}
        sizes={sizes}
        loading={eager ? "eager" : "lazy"}
        decoding={eager ? "sync" : "async"}
        fetchpriority={eager ? "high" : "auto"}
        formats={["avif", "webp"]}
      />
    ) : (
      <Picture
        src={slides[0].src}
        alt={slides[0].alt}
        width={slides[0].src.width}
        height={slides[0].src.height}
        loading={eager ? "eager" : "lazy"}
        decoding={eager ? "sync" : "async"}
        fetchpriority={eager ? "high" : "auto"}
        formats={["avif", "webp"]}
      />
    )
  }

  <button
    type="button"
    class="expand"
    data-expand
    aria-label={label ? `Expand ${label} photo` : "Expand photo"}
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="15 3 21 3 21 9"></polyline>
      <polyline points="9 21 3 21 3 15"></polyline>
      <line x1="21" y1="3" x2="14" y2="10"></line>
      <line x1="3" y1="21" x2="10" y2="14"></line>
    </svg>
  </button>

  {
    total > 1 && (
      <div class="indicator" aria-hidden="true">
        <span class="counter" data-indicator>
          01 / {totalLabel}
        </span>
        {label && <span class="label-text">{label}</span>}
      </div>
    )
  }

  <dialog class="lightbox" data-lightbox aria-label={label ? `${label} photos, expanded` : "Expanded photos"}>
  <div class="lightbox-stage">
    {
      slides.map((s, i) => (
        <div class="lightbox-slide" data-lightbox-slide hidden={i !== 0}>
          <img
            src={s.src.src}
            alt={s.alt}
            width={s.src.width}
            height={s.src.height}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))
    }
  </div>
  <div class="lightbox-bar">
    {
      total > 1 && (
        <>
          <button type="button" class="lb-nav" data-lb-prev aria-label="Previous photo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <span class="lb-indicator" data-lb-indicator>
            01 / {totalLabel}
          </span>
          <button type="button" class="lb-nav" data-lb-next aria-label="Next photo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </>
      )
    }
    <button type="button" class="lb-close" data-lb-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  </dialog>
</div>

<script>
  const pad = (n: number) => String(n).padStart(2, "0");

  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((el) => {
    const slides = Array.from(
      el.querySelectorAll<HTMLElement>("[data-slide]"),
    );
    const indicator = el.querySelector<HTMLElement>("[data-indicator]");
    const expandBtn = el.querySelector<HTMLButtonElement>("[data-expand]");
    const cycleBtn = el.querySelector<HTMLButtonElement>("[data-cycle]");

    const lightbox = el.querySelector<HTMLDialogElement>("[data-lightbox]");
    const lbSlides = Array.from(
      lightbox?.querySelectorAll<HTMLElement>("[data-lightbox-slide]") ?? [],
    );
    const lbIndicator = lightbox?.querySelector<HTMLElement>("[data-lb-indicator]");
    const lbPrev = lightbox?.querySelector<HTMLButtonElement>("[data-lb-prev]");
    const lbNext = lightbox?.querySelector<HTMLButtonElement>("[data-lb-next]");
    const lbClose = lightbox?.querySelector<HTMLButtonElement>("[data-lb-close]");

    const total = slides.length || lbSlides.length;
    if (total === 0) return;

    let i = 0;

    const showSlide = (next: number) => {
      i = ((next % total) + total) % total;
      slides.forEach((s, idx) => (s.hidden = idx !== i));
      lbSlides.forEach((s, idx) => (s.hidden = idx !== i));
      const text = `${pad(i + 1)} / ${pad(total)}`;
      if (indicator) indicator.textContent = text;
      if (lbIndicator) lbIndicator.textContent = text;
    };

    cycleBtn?.addEventListener("click", () => showSlide(i + 1));

    // Page scroll lock for the modal. iOS Safari ignores
    // body { overflow: hidden } for the document scroll, so we
    // also have to fix the body in place at the current scroll
    // position and restore it on close. Standard pattern.
    let savedScroll = 0;
    expandBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      savedScroll = window.scrollY;
      document.body.style.position = "fixed";
      document.body.style.top = `-${savedScroll}px`;
      document.body.style.left = "0";
      document.body.style.right = "0";
      document.body.style.overflow = "hidden";
      lightbox?.showModal();
    });

    lightbox?.addEventListener("close", () => {
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      document.body.style.overflow = "";
      window.scrollTo(0, savedScroll);
    });

    lbClose?.addEventListener("click", (e) => {
      e.stopPropagation();
      lightbox?.close();
    });
    lbPrev?.addEventListener("click", (e) => {
      e.stopPropagation();
      e.preventDefault();
      showSlide(i - 1);
    });
    lbNext?.addEventListener("click", (e) => {
      e.stopPropagation();
      e.preventDefault();
      showSlide(i + 1);
    });

    // Click on the dark backdrop closes the dialog. Clicks on the
    // dialog content fall through to their own handlers.
    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) lightbox.close();
    });

    // Arrow keys navigate inside the lightbox.
    lightbox?.addEventListener("keydown", (e) => {
      if (total < 2) return;
      if (e.key === "ArrowLeft") showSlide(i - 1);
      else if (e.key === "ArrowRight") showSlide(i + 1);
    });
  });
</script>

<style>
  .gallery {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: var(--bg2);
  }

  .cycle {
    display: block;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: none;
    color: inherit;
    font: inherit;
    text-align: left;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .cycle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  .slide {
    width: 100%;
    height: 100%;
  }

  .gallery :global(picture),
  .gallery :global(picture > img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: var(--gallery-fit, cover);
  }

  .indicator {
    position: absolute;
    bottom: 6px;
    right: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    background: rgba(11, 11, 13, 0.72);
    color: var(--fg);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    pointer-events: none;
    backdrop-filter: blur(4px);
  }

  .indicator .label-text {
    color: var(--fg-mute);
  }

  /* Expand button: fixed 44x44 hit area in the bottom-left so
     it doesn't compete with the indicator pill in the bottom-right. */
  .expand {
    position: absolute;
    bottom: 6px;
    left: 6px;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(11, 11, 13, 0.72);
    color: var(--fg);
    cursor: pointer;
    backdrop-filter: blur(4px);
    -webkit-tap-highlight-color: transparent;
  }

  .expand::before {
    /* extend the touch target to 44px without growing the visible button */
    content: "";
    position: absolute;
    inset: -4px;
  }

  .expand svg {
    width: 14px;
    height: 14px;
  }

  .expand:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Lightbox dialog. Layout properties (size + flex) are scoped to
     [open] so the closed state inherits the UA `dialog { display:
     none }`. Without the [open] guard, our `display: flex` on the
     base rule would beat the UA rule and the dialog would be
     visible at all times.

     position: fixed + inset: 0 overrides the UA default
     position: absolute, which would position the dialog relative
     to the .gallery (because .gallery is position: relative) and
     push the 100vw/100vh dialog off-screen by the gallery's
     offset. fixed pins the dialog to the viewport regardless of
     where it sits in the DOM. */
  .lightbox {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    border: 0;
    border-radius: 0;
    overflow: hidden;
  }

  .lightbox[open] {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .lightbox::backdrop {
    background: rgba(11, 11, 13, 0.92);
  }

  .lightbox-stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    overflow: hidden;
    /* Reserve space; the bar at the bottom takes its natural height. */
    min-height: 0;
  }

  .lightbox-slide {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-slide :global(picture),
  .lightbox-slide :global(picture > img) {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .lightbox-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 8px 12px;
    border-top: 1px solid var(--line);
    background: var(--bg2);
  }

  .lb-nav,
  .lb-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 0 12px;
    background: none;
    border: 0;
    color: var(--fg);
    font: inherit;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .lb-close {
    margin-left: auto;
  }

  .lb-nav svg,
  .lb-close svg {
    width: 18px;
    height: 18px;
  }

  .lb-indicator {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }

  .lb-nav:focus-visible,
  .lb-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .gallery :global(picture > img) {
      transition: opacity 0.15s ease;
    }
  }
</style>
