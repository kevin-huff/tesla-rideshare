---
import MonoLabel from "./atoms/MonoLabel.astro";
import Chip from "./atoms/Chip.astro";
import UnderlinedLink from "./atoms/UnderlinedLink.astro";
import Photo from "./atoms/Photo.astro";
import headshot from "../assets/headshot.jpg";

const interests = [
  "Software Engineer",
  "AI tooling",
  "Simulation games",
  "Chatbots",
  "Tesla",
  "Space",
  "Springfield Stuff",
];
---

<div class="meet-kevin" data-component="MeetKevin">
  <div class="row">
    <div class="headshot">
      <Photo
        src={headshot}
        alt="Kevin Huff."
        width={88}
        height={88}
        densities={[1, 2, 3]}
        fit="cover"
      />
    </div>
    <p class="bio">
      I software engineer for a federal contractor by day. Off the clock I drive my Tesla and tinker with whatever caught my eye that week.
      The Tesla does the driving. About 92% of my miles are on Full Self Driving, so sit back. I will too, and enjoy the ride.
      On the side, I build IRL setups and chatbots for Twitch streamers who are more successful than me. I enjoy being a part of those communities.
    </p>
  </div>

  <div class="currently">
    <MonoLabel>currently into</MonoLabel>
  </div>
  <div class="chips">
    {interests.map((label) => <Chip label={label} />)}
  </div>

  <UnderlinedLink
    href="https://www.linkedin.com/in/mrhuff/"
    external
    accent
    trackId="linkedin"
  >
    LinkedIn — for the resume crowd
  </UnderlinedLink>
</div>

<style>
  .row {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 20px;
  }

  .headshot {
    flex-shrink: 0;
    width: 88px;
  }

  .headshot :global(img) {
    width: 88px;
    height: 88px;
    border-radius: 6px;
  }

  .bio {
    margin: 0;
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg);
  }

  .bio-todo {
    color: var(--fg-mute);
  }

  .currently {
    margin-bottom: 10px;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }
</style>
