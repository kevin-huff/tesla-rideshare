---
import MonoLabel from "./atoms/MonoLabel.astro";
import Photo from "./atoms/Photo.astro";
import ChannelCard from "./kevin-show/ChannelCard.astro";
import clip1 from "../assets/clip-1.jpg";
import clip2 from "../assets/clip-2.jpg";

type Props = {
  channel?: string;
  url?: string;
};

const { channel = "ZilchGnu", url = "https://twitch.tv/ZilchGnu" }: Props =
  Astro.props;

const clips = [
  {
    src: clip1,
    alt: "Recent stream clip.",
    href: "https://www.twitch.tv/zilchgnu/clip/AltruisticElegantDotterelAllenHuhu-KmvMov1ybatk2Upg",
  },
  {
    src: clip2,
    alt: "Recent stream clip.",
    href: "https://www.twitch.tv/zilchgnu/clip/AmorphousDeadHedgehogPicoMause-cOMeu-j17EVRALnN",
  },
];
---

<div class="kevin-show" data-component="KevinShow">
  <p class="lead">
    Twice a week I turn the camera on and stream whatever I'm building,
    breaking, or thinking about. Tech, sometimes games, occasionally the Tesla.
  </p>

  <ChannelCard channel={channel} url={url} />

  <div class="clips-label">
    <MonoLabel>recent clips</MonoLabel>
  </div>
  <div class="clips">
    {
      clips.map((clip) => (
        <a
          class="clip"
          href={clip.href}
          target="_blank"
          rel="noopener noreferrer"
          data-track="twitch-clip"
        >
          <Photo
            src={clip.src}
            alt={clip.alt}
            widths={[200, 400]}
            sizes="(min-width: 720px) 360px, 50vw"
            fit="cover"
          />
        </a>
      ))
    }
  </div>
</div>

<style>
  .lead {
    margin: 0 0 18px;
    font-size: 15px;
    color: var(--fg-dim);
    line-height: 1.55;
  }

  .clips-label {
    margin: 24px 0 10px;
  }

  .clips {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  /* Force a 16:9 box on each clip so both render the same size
     even though the source thumbnails are different aspect ratios.
     Photos object-fit: cover (set on the Photo via the fit prop)
     so the image fills the box without letterboxing. */
  .clip {
    display: block;
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg2);
  }

  .clip :global(figure),
  .clip :global(figure img) {
    width: 100%;
    height: 100%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .clip {
      transition:
        transform 0.15s ease,
        outline-color 0.15s ease;
    }
  }

  .clip:hover {
    outline: 1px solid var(--line2);
    outline-offset: 2px;
  }
</style>
