---
type Props = {
  href?: string;
  channel?: string;
  trackId?: string;
};

const {
  href = "https://twitch.tv/ZilchGnu",
  channel = "ZilchGnu",
  trackId = "twitch-follow",
}: Props = Astro.props;
---

<a
  href={href}
  rel="noopener noreferrer"
  target="_blank"
  data-track={trackId}
  class="follow"
  aria-label={`Follow ${channel} on Twitch`}
>
  Follow
</a>

<style>
  .follow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 16px;
    background: var(--accent);
    color: #000;
    font-size: 13px;
    font-weight: 600;
    border: none;
    border-radius: 999px;
    font-family: inherit;
    cursor: pointer;
  }

  .follow:focus-visible {
    outline-offset: 3px;
  }
</style>
