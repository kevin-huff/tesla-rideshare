---
import LiveDot from "../atoms/LiveDot.astro";
import MonoLabel from "../atoms/MonoLabel.astro";
import Photo from "../atoms/Photo.astro";
import FollowButton from "./FollowButton.astro";
import banner from "../../assets/channel-banner.jpg";

type ScheduleRow = { day: string; time: string; title: string };

type Props = {
  channel?: string;
  url?: string;
  live?: boolean;
  streamTitle?: string;
  schedule?: ScheduleRow[];
};

const {
  channel = "ZilchGnu",
  url = "https://twitch.tv/ZilchGnu",
  live = false,
  streamTitle,
  schedule = [
    { day: "fri", time: "5:00pm CT", title: "driving" },
    { day: "sat", time: "8:00am CT", title: "early morning driving" },
    { day: "sun", time: "12:00pm CT", title: "church crowd streaming" },
  ],
}: Props = Astro.props;
---

<article class="channel-card">
  <Photo
    src={banner}
    alt="The Kevin Show channel banner."
    widths={[400, 720]}
    sizes="(min-width: 720px) 720px, 100vw"
  />

  <div class="body">
    <div class="row">
      <div class="avatar" aria-hidden="true">K</div>
      <div class="name-status">
        <div class="name">{channel}</div>
        {
          live && (
            <div class="status">
              <LiveDot />
              <MonoLabel>
                live{streamTitle && ` · ${streamTitle}`}
              </MonoLabel>
            </div>
          )
        }
      </div>
      <FollowButton href={url} channel={channel} />
    </div>

    <div class="schedule-label">
      <MonoLabel>schedule</MonoLabel>
    </div>
    <div class="schedule">
      {
        schedule.map((s) => (
          <div class="schedule-row">
            {s.day} · {s.time} – {s.title}
          </div>
        ))
      }
    </div>
  </div>
</article>

<style>
  .channel-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg2);
  }

  .body {
    padding: 14px 14px 16px;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .avatar {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1f1f24;
    color: var(--fg);
    border-radius: 18px;
    font-size: 13px;
    font-weight: 600;
  }

  .name-status {
    flex: 1;
    min-width: 0;
  }

  .name {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--fg);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
  }

  .schedule-label {
    margin-bottom: 8px;
  }

  .schedule-row {
    font-size: 13.5px;
    color: var(--fg);
    line-height: 1.7;
  }
</style>
