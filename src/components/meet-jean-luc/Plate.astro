---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = {
  /** Plate photo. Required — this component IS the plate visual now. */
  photo: ImageMetadata;
  /** Plate text, used for the alt label. */
  text?: string;
  photoAlt?: string;
};

const { photo, text = "PICARD", photoAlt }: Props = Astro.props;

const finalPhotoAlt = photoAlt ?? `License plate: ${text}.`;

// Render at 200px wide; height derives from the source aspect.
const photoWidth = 200;
const photoHeight = Math.round((photoWidth * photo.height) / photo.width);
---

<div class="plate-row">
  <Picture
    class="plate-photo"
    src={photo}
    alt={finalPhotoAlt}
    width={photoWidth}
    height={photoHeight}
    loading="lazy"
    decoding="async"
    formats={["avif", "webp"]}
  />
</div>

<style>
  .plate-row {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .plate-row :global(.plate-photo) {
    width: 200px;
    height: auto;
  }
</style>
