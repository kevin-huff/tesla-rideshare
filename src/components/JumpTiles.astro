---
import MonoLabel from "./atoms/MonoLabel.astro";

const tiles = [
  { idx: "01", label: "The Tesla", href: "#tesla" },
  { idx: "02", label: "Springfield", href: "#springfield" },
  { idx: "03", label: "Work", href: "#work" },
];
---

<nav class="jump" aria-label="Jump to section" data-component="JumpTiles">
  {
    tiles.map((tile) => (
      <a href={tile.href} class="tile">
        <span class="idx">
          <MonoLabel accent>{tile.idx}</MonoLabel>
        </span>
        <span class="label">{tile.label}</span>
        <span class="down" aria-hidden="true">
          ↓
        </span>
      </a>
    ))
  }
</nav>

<style>
  .jump {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    padding: 0 22px 22px;
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .tile {
    display: block;
    padding: 12px 12px 14px;
    background: var(--bg2);
    border: 1px solid var(--line);
    border-radius: 10px;
    color: var(--fg);
    min-height: 44px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .tile {
      transition:
        border-color 0.15s ease,
        background 0.15s ease;
    }
  }

  .tile:hover {
    border-color: var(--line2);
    background: var(--bg3);
  }

  .idx {
    display: block;
    margin-bottom: 14px;
  }

  .label {
    display: block;
    font-size: 14px;
    font-weight: 500;
  }

  .down {
    display: block;
    margin-top: 6px;
    font-size: 12px;
    color: var(--fg-mute);
  }
</style>
