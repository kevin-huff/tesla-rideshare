---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import MonoLabel from "./MonoLabel.astro";

type Props = {
  src: ImageMetadata;
  alt: string;
  /** Intrinsic display width. Defaults to source width. */
  width?: number;
  /** Intrinsic display height. Defaults to source height. */
  height?: number;
  /** Responsive variants Astro should generate (px). Mutually exclusive with width/height. */
  widths?: number[];
  /** sizes attribute, paired with widths. */
  sizes?: string;
  /** Pixel densities Astro should generate for hi-DPI (e.g., [1, 2]). */
  densities?: number[];
  /** Box-model fit when CSS overrides intrinsic dimensions. */
  fit?: "cover" | "contain" | "fill" | "none" | "scale-down";
  eager?: boolean;
  caption?: string;
};

const {
  src,
  alt,
  width,
  height,
  widths,
  sizes,
  densities,
  fit,
  eager = false,
  caption,
}: Props = Astro.props;

const loading = eager ? "eager" : "lazy";
const decoding = eager ? "sync" : "async";
const fetchpriority = eager ? "high" : "auto";
const formats = ["avif", "webp"] as const;
---

<figure class="photo" style={fit ? `--photo-fit:${fit}` : undefined}>
  {
    widths ? (
      <Picture
        src={src}
        alt={alt}
        widths={widths}
        sizes={sizes}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
        formats={formats as unknown as ("avif" | "webp")[]}
      />
    ) : (
      <Picture
        src={src}
        alt={alt}
        width={width ?? src.width}
        height={height ?? src.height}
        densities={densities}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
        formats={formats as unknown as ("avif" | "webp")[]}
      />
    )
  }
  {
    caption && (
      <figcaption>
        <MonoLabel>{caption}</MonoLabel>
      </figcaption>
    )
  }
</figure>

<style>
  .photo {
    margin: 0;
  }

  .photo :global(img) {
    width: 100%;
    height: auto;
    object-fit: var(--photo-fit, initial);
  }

  figcaption {
    margin-top: 8px;
  }
</style>
