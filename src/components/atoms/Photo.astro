---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import MonoLabel from "./MonoLabel.astro";

type Props = {
  src: ImageMetadata;
  alt: string;
  width: number;
  height: number;
  eager?: boolean;
  caption?: string;
};

const { src, alt, width, height, eager = false, caption } = Astro.props;
---

<figure class="photo">
  <Picture
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={eager ? "eager" : "lazy"}
    decoding={eager ? "sync" : "async"}
    fetchpriority={eager ? "high" : "auto"}
    formats={["avif", "webp"]}
  />
  {
    caption && (
      <figcaption>
        <MonoLabel>{caption}</MonoLabel>
      </figcaption>
    )
  }
</figure>

<style>
  .photo {
    margin: 0;
  }

  figcaption {
    margin-top: 8px;
  }
</style>
