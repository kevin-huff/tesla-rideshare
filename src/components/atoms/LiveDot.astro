---
type Props = {
  pulse?: boolean;
};

const { pulse = false }: Props = Astro.props;
---

<span class:list={["live-dot", { pulse }]} aria-hidden="true"></span>

<style>
  .live-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--live);
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
  }

  @media (prefers-reduced-motion: no-preference) {
    .live-dot.pulse {
      animation: live-dot-pulse 1s ease-in-out infinite;
    }
  }

  @keyframes live-dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
    }
    50% {
      box-shadow: 0 0 14px rgba(52, 211, 153, 0.95);
    }
  }
</style>
