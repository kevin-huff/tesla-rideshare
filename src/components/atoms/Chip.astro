---
type Props = {
  label?: string;
};

const { label } = Astro.props;
---

<span class="chip">
  {label ?? <slot />}
</span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border: 1px solid var(--line2);
    border-radius: 999px;
    color: var(--fg);
    font-size: 12.5px;
    line-height: 1;
  }
</style>
