---
import MonoLabel from "./atoms/MonoLabel.astro";
import Photo from "./atoms/Photo.astro";
import SpecGrid from "./meet-jean-luc/SpecGrid.astro";
import Plate from "./meet-jean-luc/Plate.astro";
import FAQ from "./meet-jean-luc/FAQ.astro";
import ReferralCard from "./meet-jean-luc/ReferralCard.astro";
import exterior from "../assets/tesla-exterior.jpg";
import interior from "../assets/tesla-interior.jpg";
import screen from "../assets/tesla-screen.jpg";
---

<div class="meet-jean-luc" data-component="MeetJeanLuc">
  <div class="subhead">
    <MonoLabel>the model y</MonoLabel>
  </div>

  <div class="photos">
    <Photo
      src={exterior}
      alt="The Tesla, three-quarter front view."
      widths={[400, 720]}
      sizes="(min-width: 720px) 720px, 100vw"
    />
    <div class="photos-row">
      <Photo
        src={interior}
        alt="Tesla interior."
        widths={[200, 400]}
        sizes="(min-width: 720px) 360px, 50vw"
      />
      <Photo
        src={screen}
        alt="Tesla dashboard screen."
        widths={[200, 400]}
        sizes="(min-width: 720px) 360px, 50vw"
      />
    </div>
  </div>

  <SpecGrid />

  <div class="plate">
    <Plate />
  </div>

  <FAQ />

  <ReferralCard />
</div>

<style>
  .subhead {
    /* pull the mono subhead up under the H2's bottom margin (22px) */
    margin: -16px 0 18px;
  }

  .photos-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 8px;
  }

  .plate {
    margin-top: 22px;
  }
</style>
