---
type Props = {
  href: string;
  label?: string;
  trackId?: string;
};

const {
  href,
  label = href.replace(/^mailto:/, ""),
  trackId,
}: Props = Astro.props;
---

<a href={href} data-track={trackId} class="email-cta">
  {label} →
</a>

<style>
  .email-cta {
    display: block;
    text-align: center;
    padding: 14px 16px;
    border: 1px solid var(--accent);
    border-radius: 10px;
    color: var(--accent);
    font-size: 14.5px;
    font-weight: 500;
  }
</style>
