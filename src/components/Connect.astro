---
import MonoLabel from "./atoms/MonoLabel.astro";

type Tile = {
  key: string;
  value: string;
  href: string;
  trackId: string;
  external?: boolean;
};

const tiles: Tile[] = [
  {
    key: "email",
    value: "kevin@kevnet.cloud",
    href: "mailto:kevin@kevnet.cloud",
    trackId: "email-connect",
  },
  {
    key: "twitch",
    value: "/ZilchGnu",
    href: "https://twitch.tv/ZilchGnu",
    trackId: "twitch-connect",
    external: true,
  },
  {
    key: "linkedin",
    value: "/in/mrhuff",
    href: "https://www.linkedin.com/in/mrhuff/",
    trackId: "linkedin-connect",
    external: true,
  },
  {
    key: "github",
    value: "@kevin-huff",
    href: "https://github.com/kevin-huff",
    trackId: "github-connect",
    external: true,
  },
];
---

<section class="connect">
  <div class="label">
    <MonoLabel>connect</MonoLabel>
  </div>
  <div class="grid">
    {
      tiles.map((t) => (
        <a
          href={t.href}
          class="tile"
          data-track={t.trackId}
          rel={t.external ? "noopener noreferrer" : undefined}
          target={t.external ? "_blank" : undefined}
        >
          <div class="key">
            <MonoLabel>{t.key}</MonoLabel>
          </div>
          <div class="value">{t.value}</div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .connect {
    padding: 28px 22px;
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .label {
    margin-bottom: 14px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  @media (min-width: 720px) {
    .grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .tile {
    display: block;
    padding: 14px;
    background: var(--bg);
    color: var(--fg);
    min-height: 44px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .tile {
      transition: background 0.15s ease;
    }
  }

  .tile:hover {
    background: var(--bg3);
  }

  .key {
    margin-bottom: 4px;
  }

  .value {
    font-size: 13.5px;
    color: var(--fg);
  }
</style>
