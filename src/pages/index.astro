---
import Page from "../components/Page.astro";
import TopNav from "../components/TopNav.astro";
import Hero from "../components/Hero.astro";
import JumpTiles from "../components/JumpTiles.astro";
import Section from "../components/Section.astro";
import Rule from "../components/Rule.astro";
import MeetKevin from "../components/MeetKevin.astro";
import MeetJeanLuc from "../components/MeetJeanLuc.astro";
import KevinShow from "../components/KevinShow.astro";
import WorkBuckets from "../components/WorkBuckets.astro";
import DirectBooking from "../components/DirectBooking.astro";
import Connect from "../components/Connect.astro";
import Footer from "../components/Footer.astro";
import PhotoPlaceholder from "../components/atoms/PhotoPlaceholder.astro";
---

<Page
  title="ride.kevnet.cloud"
  description="Kevin Huff. Springfield Tesla driver, tech guy, Twitch streamer."
>
  <TopNav />
  <Hero>
    {/* TODO(launch): swap for <Photo eager> with the real hero (Kevin + Tesla,
        landscape, 4:5 mobile / 16:9 desktop, golden hour). Add a matching
        <link rel="preload" as="image"> via Page's head slot for LCP. */}
    <PhotoPlaceholder
      slot="photo"
      caption="HERO · KEVIN + MODEL Y"
      height={260}
    />
  </Hero>
  <JumpTiles />
  <Section index="01 / WHO" title="Meet Kevin">
    <MeetKevin />
  </Section>
  <Section index="02 / THE CAR · PICARD" title="Meet Jean-Luc" id="tesla">
    <MeetJeanLuc />
  </Section>
  <Section index="03 / TWITCH" title="The Kevin Show" id="show">
    <KevinShow />
  </Section>
  <Section index="04 / WORK" title="Work With Me" id="work">
    <WorkBuckets />
  </Section>
  <Rule />
  <DirectBooking />
  <Rule />
  <Connect />
  <Footer />
</Page>
